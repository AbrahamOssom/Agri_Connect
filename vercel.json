{
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1"
        },
        "api/login.php": {
            "runtime": "vercel-php@0.7.1"
        },
        "api/register.php": {
            "runtime": "vercel-php@0.7.1"
        },
        "api/connect.php": {
            "runtime": "vercel-php@0.7.1"
        },
        "api/search.php": {
            "runtime": "vercel-php@0.7.1"
        },
        "api/dbh.php": {
            "runtime": "vercel-php@0.7.1"
        },
        "api/subscribe.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/login.php",
            "dest": "/api/login.php"
        },
        {
            "src": "/register.php",
            "dest": "/api/register.php"
        },
        {
            "src": "/connect.php",
            "dest": "/api/connect.php"
        },
        {
            "src": "/search.php",
            "dest": "/api/search.php"
        },
        {
            "src": "/dbh.php",
            "dest": "/api/dbh.php"
        },
        {
            "src": "/subscribe.php",
            "dest": "/api/subscribe.php"
        },
        {
            "src": "/index.php",
            "dest": "/api/index.php"
        },
        {
            "src": "/(.*)",
            "dest": "/main/main.html"
        }
    ]
}